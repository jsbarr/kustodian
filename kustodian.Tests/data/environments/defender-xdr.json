  "functions": {
    "AddFlag": {
      "paramSignature": "T:(*)",
      "body": "T | extend IsFlagged = true"
    },
    "TagSeverity": {
      "paramSignature": "T:(*), severity:int",
      "body": "T | extend Severity = severity"
    },
    "TagLabel": {
      "paramSignature": "T:(*), label:string",
      "body": "T | extend Label = label"
    },
    "ScaleScore": {
      "paramSignature": "n:long, factor:long",
      "body": "n * factor"
    },
    "Enrich": {
      "paramSignature": "T:(*), category:string, score:int",
      "body": "T | extend Category = category, Score = score"
    },
    "TagScore": {
      "paramSignature": "T:(*), score:long",
      "body": "T | extend TaggedScore = score"
    },
    "FunctionWithJoin": {
      "paramSignature": "T:(*)",
      "body": "T | extend __TEMPKEY__=1 | join kind=leftouter (datatable(__TEMPKEY__:long, NewCol:long) [1, 12345]) on __TEMPKEY__ | project-away __TEMPKEY__, __TEMPKEY__1"
    },
    "FileProfile": {
      "paramSignature": "T:(*), HashColumn:string, Limit:long",
      "body": "T | extend __TEMPKEY__=1 | join kind=leftouter (datatable(__TEMPKEY__:long, SHA1:string, SHA256:string, MD5:string, FileSize:int, GlobalPrevalence:int, GlobalFirstSeen:datetime, GlobalLastSeen:datetime, Signer:string, Issuer:string, SignerHash:string, IsCertificateValid:bool, IsRootSignerMicrosoft:bool, SignatureState:string, IsExecutable:bool, ThreatName:string, Publisher:string, SoftwareName:string, ProfileAvailability:string) ['','','',int(0),datetime(null),datetime(null),'','','',false,false,'',false,'','','','']) on __TEMPKEY__ | project-away __TEMPKEY__, __TEMPKEY__1"
