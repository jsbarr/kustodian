          "column": "Timestamp",
          "table": "DeviceEvents"
        }
      },
      {
        "name": "DeviceId",
        "type": "string",
        "provenance": {
          "column": "DeviceId",
          "table": "DeviceEvents"
        }
      },
      {
        "name": "ReportId",
        "type": "long",
        "provenance": {
          "column": "ReportId",
          "table": "DeviceEvents"
        }
      }
    ]
  }
