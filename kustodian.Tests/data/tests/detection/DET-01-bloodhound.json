  "id": "DET-01",
  "name": "Detection: BloodHound process detection via let-bound dynamic list and has_any filter",
  "input": {
    "query": "let BloodhoundCommands = dynamic(['-collectionMethod', 'invoke-bloodhound', 'get-bloodHounddata']);\nDeviceProcessEvents\n| where ProcessCommandLine has_any (BloodhoundCommands)\n| project Timestamp, ReportId, DeviceId, DeviceName, AccountName, AccountDomain, ProcessCommandLine, FileName, InitiatingProcessCommandLine, InitiatingProcessFileName",
