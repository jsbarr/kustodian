{
  "id": "DET-04",
  "name": "Detection: shadow copy deletion — let with multi-element ransomware command list and has_any filter",
  "input": {
    "query": "let CommonRansomwareCommands = dynamic(['vssadmin.exe delete shadows /all /quiet', 'wmic.exe shadowcopy delete', 'wbadmin delete catalog -quiet', 'Get-WmiObject Win32_Shadowcopy | ForEach-Object {$_.Delete();}']);\nDeviceProcessEvents\n| where ProcessCommandLine has_any (CommonRansomwareCommands)\n| project Timestamp, ReportId, DeviceId, DeviceName, AccountName, ProcessCommandLine, InitiatingProcessFileName, InitiatingProcessCommandLine",
    "impactedEntityField": "DeviceId",
    "environment": "defender-xdr"
  },
