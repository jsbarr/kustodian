    "outputColumns": [
      {
        "name": "Timestamp",
        "provenance": {
          "column": "Timestamp",
          "table": "DeviceEvents"
        }
      },
      {
        "name": "DeviceId",
        "provenance": {
          "column": "DeviceId",
          "table": "DeviceEvents"
        }
      },
      {
        "name": "ReportId",
        "provenance": {
          "column": "ReportId",
          "table": "DeviceEvents"
        }
      }
    ]
  }
}